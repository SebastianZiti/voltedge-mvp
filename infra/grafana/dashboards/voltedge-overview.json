{
  "id": null,
  "title": "VoltEdge API - DevSecOps Observability",
  "uid": "voltedge-ops",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "browser",
  "tags": [
    "voltedge",
    "devsecops",
    "flask",
    "sqlite"
  ],
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP requests per sekund (alle endpoints)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum by (method, path) (rate(flask_http_request_duration_seconds_count[1m]))",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP request latency p95 (sekunder)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(flask_http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "id": 3,
      "title": "API kald der lykkes (total)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(flask_http_request_total{status=~\"2..|3..\"})",
          "legendFormat": "Succes"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "title": "API kald der fejler (total)",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(flask_http_request_total{status=~\"4..|5..\"})",
          "legendFormat": "Fejl"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Database fejl (total)",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(voltedge_db_errors_total)",
          "legendFormat": "DB fejl"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Database klar",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "voltedge_db_ready",
          "legendFormat": "DB ready"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "HTTP fejlrate fordelt på endpoint",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum by (status, method, path) (rate(flask_http_request_total{status=~\"4..|5..\"}[1m]))",
          "legendFormat": "{{status}} {{method}} {{path}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "Fejlede API kald fordelt på endpoint (total)",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum by (status, method, path) (flask_http_request_total{status=~\"4..|5..\"})",
          "legendFormat": "{{status}} {{method}} {{path}}"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "graphMode": "none",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      }
    },
    {
      "id": 8,
      "title": "HTTP statuskoder",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(flask_http_request_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "SQLite queries per sekund",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum by (operation) (rate(voltedge_db_queries_total[1m]))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "SQLite query latency p95 (sekunder)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (operation, le) (rate(voltedge_db_query_duration_seconds_bucket[1m])))",
          "legendFormat": "{{operation}} p95"
        }
      ]
    },
    {
      "id": 11,
      "title": "SQLite DB filstørrelse",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "voltedge_db_file_size_bytes",
          "legendFormat": "SQLite bytes"
        }
      ]
    },
    {
      "id": 12,
      "title": "Prometheus scrape varighed",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "scrape_duration_seconds{job=\"voltedge-app\"}",
          "legendFormat": "scrape duration"
        }
      ]
    }
  ]
}
