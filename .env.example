# VoltEdge MVP - Eksempel paa miljoevariabler
#
# Hvad er denne fil?
# ------------------
# .env.example dokumenterer hvilke env-variabler appen og docker-compose
# laeser. Filen indeholder KUN safe placeholder-vaerdier og er commitet
# til Git, saa nye udviklere/censor kan se hvad de skal saette.
#
# .env (uden ".example") MAA IKKE commits - se .gitignore. Den ville
# indeholde rigtige secrets (fx en produktion-SECRET_KEY).
#
# Sadan bruger du den:
#   1) cp .env.example .env
#   2) Aabn .env og udfyld vaerdier til dit miljoe.
#   3) (Valgfrit) Source filen foer du koerer appen direkte:
#        set -a; source .env; set +a; python app.py
#      Eller laes den ind i docker via:
#        docker run --env-file .env voltedge-mvp:latest
#
# Bemaerk: docker-compose.yml har dev-defaults inline (admin/admin,
# default SECRET_KEY osv.) saa "git clone + docker compose up" virker
# uden .env. Denne fil er saerligt relevant naar du deployer udenfor
# compose (fx til en server med SERVICE_ENV=production).


# === Flask / app ===

# development = lokal udvikling (default-SECRET_KEY tilladt, seed-demo aaben)
# test        = CI / staging (SECRET_KEY paakraevet)
# production  = live drift (SECRET_KEY paakraevet, seed-demo blokeret)
SERVICE_ENV=development

# Logniveau for Python's logging. Almindelige vaerdier: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Aktiverer Flask debugger + auto-reload. SKAL vaere 0 udenfor lokal udvikling
# (debugger = remote code execution-vektor).
FLASK_DEBUG=0

# Hemmelig noegle Flask bruger til at signere sessions/cookies.
# I development bruges en default hvis denne er tom. I test/production
# fejler appen ved opstart hvis SECRET_KEY ikke er sat til en stark vaerdi.
# Generer en sikker vaerdi med:  openssl rand -hex 32
SECRET_KEY=

# Sti til SQLite-databasefilen. Tom = brug default i database.py.
DB_PATH=


# === Grafana (kun relevant hvis du overrider docker-compose) ===

# Default i compose er admin/admin (dev-bekvemt). Saet egne vaerdier her
# hvis du koerer compose mod et delt miljoe.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false
