# VoltEdge MVP — miljøvariabler
# Kopiér til .env og udfyld egne værdier. .env er gitignored.

SERVICE_ENV=development
LOG_LEVEL=INFO
FLASK_DEBUG=0

# Generer med: openssl rand -hex 32
SECRET_KEY=

DB_PATH=

# Grafana (kun relevant hvis du overrider docker-compose defaults)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false
